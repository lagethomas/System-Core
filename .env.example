# -----------------------------------------------------------------------------
# SaaSFlow Core - Arquivo de Exemplo do Ambiente (.env)
# Atenção: Renomeie este arquivo para .env em produção e defina as chaves reais.
# -----------------------------------------------------------------------------

# --- APP CONFIGURATION ---
APP_ENV=development             # 'development' ou 'production'
APP_TIMEZONE=America/Sao_Paulo  # Timezone padrão do sistema
APP_DATE_FORMAT="d/m/Y H:i"     # Formato de data principal
SITE_URL=http://localhost       # URL base do sistema (ex: https://meusaas.com)

# --- DATABASE (MariaDB) ---
DB_HOST=127.0.0.1               # Host do servidor de banco de dados
DB_PORT=3306                    # Porta (padrão 3306)
DB_NAME=saasflow_db             # Nome da base de dados
DB_USER=root                    # Utilizador da DB
DB_PASS=                        # Password da DB
DB_CHARSET=utf8mb4              # Charset (recomendado utf8mb4)

# --- CACHE (Redis) ---
# Se REDIS_HOST estiver definido, o Cache:: utilizará Redis; caso contrário, usará arquivos.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- SECURITY & UTILS ---
DB_MIGRATION_TOKEN=76269223e7      # Token para rodar migrate.php via browser
APP_KEY=                           # Chave de criptografia (32 caracteres recomendados)
SYSTEM_LOGS_ENABLED=1             # 0 para silenciar logs de erros no arquivo
